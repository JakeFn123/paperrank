{
  "input_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["question", "sub_queries", "source", "per_query_limit", "max_papers", "locked_concepts"],
    "properties": {
      "question": {"type": "string", "minLength": 1},
      "sub_queries": {"type": "array", "items": {"type": "string"}, "minItems": 1},
      "source": {"type": "string", "enum": ["all", "semantic_scholar", "arxiv"]},
      "per_query_limit": {"type": "integer", "minimum": 1, "maximum": 20},
      "max_papers": {"type": "integer", "minimum": 1, "maximum": 30},
      "locked_concepts": {"type": "array", "items": {"type": "string"}}
    },
    "additionalProperties": true
  },
  "output_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["papers", "search_log"],
    "properties": {
      "papers": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["paper_id", "title", "query_match_score", "rerank_score"],
          "properties": {
            "paper_id": {"type": "string"},
            "title": {"type": "string"},
            "query_match_score": {"type": "number"},
            "rerank_score": {"type": "number"}
          },
          "additionalProperties": true
        }
      },
      "search_log": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["query", "hits", "source", "status"],
          "properties": {
            "query": {"type": "string"},
            "hits": {"type": "integer"},
            "source": {"type": "string"},
            "status": {"type": "string"}
          },
          "additionalProperties": true
        }
      }
    },
    "additionalProperties": true
  }
}
